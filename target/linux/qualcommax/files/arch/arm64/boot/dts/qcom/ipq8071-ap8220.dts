/dts-v1/;

#include "ipq8074.dtsi"
#include "ipq8074-ac-cpu.dtsi"
#include "ipq8074-ess.dtsi"
#include "ipq8074-nss.dtsi"
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>

/ {
	model = "Aliyun AP8220";
	compatible = "aliyun,ap8220\0qcom,ipq8074-ap-ac02\0qcom,ipq8074";
	qcom,board-id = <0x08 0x00>;
	qcom,pmic-id = <0x00 0x00 0x00 0x00>;
	#address-cells = <0x02>;
	#size-cells = <0x02>;
	qcom,msm-id = <0x178 0x00>;
	interrupt-parent = <0x01>;

	firmware {

		qfprom {
			compatible = "qcom,qfprom-sec";
			img-addr = "J@\0";
			img-size = <0x700000>;
		};
	};

	hwlock@193d000 {
		compatible = "qcom,tcsr-mutex";
		syscon = <0x02 0x00 0x80>;
		#hwlock-cells = <0x01>;
		phandle = <0x04>;
	};

	smem {
		compatible = "qcom,smem";
		memory-region = <0x03>;
		hwlocks = <0x04 0x00>;
	};

	qti,tzlog {
		compatible = "qti,tzlog";
		interrupts = <0x00 0xf4 0x01>;
		qti,tz-diag-buf-size = <0x2000>;
		qti,tz-ring-off = <0x07>;
		qti,tz-log-pos-info-off = <0x243>;
		qti,hvc-enabled;
		qti,get-smmu-state;
	};

	qti,gadget_diag@0 {
		compatible = "qti,gadget-diag";
		status = "disabled";
	};

	smp2p-wcss {
		compatible = "qcom,smp2p";
		qcom,smem = <0x1b3 0x1ac>;
		interrupt-parent = <0x01>;
		interrupts = <0x00 0x142 0x01>;
		mboxes = <0x05 0x09>;
		qcom,local-pid = <0x00>;
		qcom,remote-pid = <0x01>;

		master-kernel {
			qcom,entry-name = "master-kernel";
			qcom,smp2p-feature-ssr-ack;
			#qcom,smem-state-cells = <0x01>;
			phandle = <0x25>;
		};

		slave-kernel {
			qcom,entry-name = "slave-kernel";
			interrupt-controller;
			#interrupt-cells = <0x02>;
			phandle = <0x23>;
		};
	};

	ctx-save {
		compatible = "qti,ctxt-save-ipq8074";
	};

	qseecom {
		compatible = "ipq807x-qseecom";
		memory-region = <0x06 0x07>;
		notify-align = <0x01>;
		status = "ok";
	};

	srd_trace {
		compatible = "srd";
	};

	soc {
		#address-cells = <0x01>;
		#size-cells = <0x01>;
		ranges = <0x00 0x00 0x00 0xffffffff>;
		compatible = "simple-bus";

		pinctrl@1000000 {
			compatible = "qcom,ipq8074-pinctrl";
			reg = <0x1000000 0x300000>;
			interrupts = <0x00 0xd0 0x04>;
			gpio-controller;
			#gpio-cells = <0x02>;
			interrupt-controller;
			#interrupt-cells = <0x02>;
			phandle = <0x10>;

			serial4-pinmux {
				pins = "gpio23\0gpio24";
				function = "blsp4_uart1";
				drive-strength = <0x08>;
				bias-disable;
				phandle = <0x0b>;
			};

			serial5-state {
				pins = "gpio9\0gpio16";
				function = "blsp5_uart";
				drive-strength = <0x08>;
				bias-disable;
				phandle = <0x0c>;
			};

			i2c-0-pinmux {
				pins = "gpio42\0gpio43";
				function = "blsp1_i2c";
				drive-strength = <0x08>;
				bias-disable;
				phandle = <0x16>;
			};

			spi-0-pins {
				pins = "gpio38\0gpio39\0gpio40\0gpio41";
				function = "blsp0_spi";
				drive-strength = <0x08>;
				bias-disable;
				phandle = <0x15>;
			};

			hsuart-pins {
				pins = "gpio46\0gpio47\0gpio48\0gpio49";
				function = "blsp2_uart";
				drive-strength = <0x08>;
				bias-disable;
				phandle = <0x14>;
			};

			qpic-pins {
				pins = "gpio1\0gpio3\0gpio4\0gpio5\0gpio6\0gpio7\0gpio8\0gpio10\0gpio11\0gpio12\0gpio13\0gpio14\0gpio15\0gpio17";
				function = "qpic";
				drive-strength = <0x08>;
				bias-disable;
				phandle = <0x19>;
			};

			button_pins {
				phandle = <0x53>;

				wps_button {
					pins = "gpio66";
					function = "gpio";
					drive-strength = <0x08>;
					bias-pull-up;
				};
			};

			usb_mux_pins {

				mux {
					pins = "gpio27";
					function = "gpio";
					drive-strength = <0x08>;
					bias-pull-down;
				};
			};

			pcie_pins {

				pcie0_rst {
					pins = "gpio58";
					function = "pcie0_rst";
					drive-strength = <0x08>;
					bias-pull-down;
				};

				pcie0_wake {
					pins = "gpio59";
					function = "pcie0_wake";
					drive-strength = <0x08>;
					bias-pull-down;
				};
			};

			mdio_pinmux {
				phandle = <0x28>;

				mux_0 {
					pins = "gpio68";
					function = "mdc";
					drive-strength = <0x08>;
					bias-pull-up;
				};

				mux_1 {
					pins = "gpio69";
					function = "mdio";
					drive-strength = <0x08>;
					bias-pull-up;
				};

				mux_2 {
					pins = "gpio33";
					function = "gpio";
					bias-pull-up;
				};

				mux_3 {
					pins = "gpio44";
					function = "gpio";
					bias-pull-up;
				};
			};

			led_pins {
				phandle = <0x54>;

				led_pwr {
					pins = "gpio46";
					function = "gpio";
					drive-strength = <0x02>;
					bias-pull-up;
				};

				led_2g {
					pins = "gpio47";
					function = "gpio";
					drive-strength = <0x02>;
					bias-pull-down;
				};

				led_5g {
					pins = "gpio48";
					function = "gpio";
					drive-strength = <0x02>;
					bias-pull-down;
				};

				led_ble {
					pins = "gpio50";
					function = "gpio";
					drive-strength = <0x02>;
					bias-pull-down;
				};
			};
		};

		interrupt-controller@b000000 {
			compatible = "qcom,msm-qgic2";
			interrupt-controller;
			#interrupt-cells = <0x03>;
			reg = <0xb000000 0x1000 0xb002000 0x1000>;
			ranges = <0x00 0xb00a000 0xffd>;
			phandle = <0x01>;

			v2m@0 {
				compatible = "arm,gic-v2m-frame";
				msi-controller;
				reg = <0x00 0xffd>;
				phandle = <0x20>;
			};
		};

		timer {
			compatible = "arm,armv8-timer";
			interrupts = <0x01 0x02 0xf08 0x01 0x03 0xf08 0x01 0x04 0xf08 0x01 0x01 0xf08>;
		};

		watchdog@b017000 {
			compatible = "qcom,kpss-wdt";
			reg = <0xb017000 0x1000>;
			interrupts = <0x00 0x03 0x01>;
			clocks = <0x08>;
		};

		timer@b120000 {
			#address-cells = <0x01>;
			#size-cells = <0x01>;
			ranges;
			compatible = "arm,armv7-timer-mem";
			reg = <0xb120000 0x1000>;
			clock-frequency = <0x124f800>;

			frame@b120000 {
				frame-number = <0x00>;
				interrupts = <0x00 0x08 0x04 0x00 0x07 0x04>;
				reg = <0xb121000 0x1000 0xb122000 0x1000>;
			};

			frame@b123000 {
				frame-number = <0x01>;
				interrupts = <0x00 0x09 0x04>;
				reg = <0xb123000 0x1000>;
				status = "disabled";
			};

			frame@b124000 {
				frame-number = <0x02>;
				interrupts = <0x00 0x0a 0x04>;
				reg = <0xb124000 0x1000>;
				status = "disabled";
			};

			frame@b125000 {
				frame-number = <0x03>;
				interrupts = <0x00 0x0b 0x04>;
				reg = <0xb125000 0x1000>;
				status = "disabled";
			};

			frame@b126000 {
				frame-number = <0x04>;
				interrupts = <0x00 0x0c 0x04>;
				reg = <0xb126000 0x1000>;
				status = "disabled";
			};

			frame@b127000 {
				frame-number = <0x05>;
				interrupts = <0x00 0x0d 0x04>;
				reg = <0xb127000 0x1000>;
				status = "disabled";
			};

			frame@b128000 {
				frame-number = <0x06>;
				interrupts = <0x00 0x0e 0x04>;
				reg = <0xb128000 0x1000>;
				status = "disabled";
			};
		};

		gcc@1800000 {
			compatible = "qcom,gcc-ipq8074";
			reg = <0x1800000 0x80000>;
			#clock-cells = <0x01>;
			#reset-cells = <0x01>;
			phandle = <0x09>;
		};

		qcom,msm-imem@8600000 {
			compatible = "qcom,msm-imem";
			reg = <0x8600000 0x1000>;
			ranges = <0x00 0x8600000 0x1000>;
			#address-cells = <0x01>;
			#size-cells = <0x01>;

			mem_dump_table@10 {
				compatible = "qcom,msm-imem-mem_dump_table";
				reg = <0x10 0x08>;
			};
		};

		dcc@b3000 {
			compatible = "qca,dcc";
			status = "ok";
			reg = <0xb3000 0x1000 0xb4000 0x800 0x4a2000 0x08>;
			reg-names = "dcc-base\0dcc-ram-base\0gcnt_lo_hi";
			clocks = <0x09 0xe6>;
			clock-names = "dcc_clk";
			no_xpu_support;
			qca,save-reg;
		};

		dma@704000 {
			compatible = "qcom,bam-v1.7.0";
			reg = <0x704000 0x20000>;
			interrupts = <0x00 0xcf 0x04>;
			clocks = <0x09 0xda>;
			clock-names = "bam_clk";
			#dma-cells = <0x01>;
			qcom,ee = <0x01>;
			qcom,controlled-remotely = <0x01>;
			status = "ok";
			phandle = <0x0a>;
		};

		crypto@73a000 {
			compatible = "qcom,crypto-v5.1";
			reg = <0x73a000 0x6000>;
			clocks = <0x09 0xda 0x09 0xdb 0x09 0xdc>;
			clock-names = "iface\0bus\0core";
			dmas = <0x0a 0x02 0x0a 0x03>;
			dma-names = "rx\0tx";
			qce,cmd_desc_support;
			status = "ok";
		};

		rng@e3000 {
			compatible = "qcom,msm-rng";
			reg = <0xe3000 0x1000>;
			clocks = <0x09 0x28>;
			clock-names = "km_clk_src";
			qcom,no-qrng-config;
		};

		qcom,apss_clk@b111000 {
			compatible = "qcom,apss-ipq807x";
			reg = <0xb111000 0x6000>;
			#clock-cells = <0x01>;
			#reset-cells = <0x01>;
		};

		serial@78b3000 {
			compatible = "qcom,msm-uartdm-v1.4\0qcom,msm-uartdm";
			reg = <0x78b3000 0x200>;
			interrupts = <0x00 0x134 0x04>;
			clocks = <0x09 0x26 0x09 0x15>;
			clock-names = "core\0iface";
			pinctrl-0 = <0x0b>;
			pinctrl-names = "default";
			status = "ok";
			tx-watermark = <0x00>;
		};

		serial@78b4000 {
			compatible = "qcom,msm-uartdm-v1.4\0qcom,msm-uartdm";
			reg = <0x78b4000 0x200>;
			interrupts = <0x00 0x135 0x04>;
			clocks = <0x09 0x27 0x09 0x15>;
			clock-names = "core\0iface";
			pinctrl-0 = <0x0c>;
			pinctrl-names = "default";
			status = "disabled";
		};

		syscon@1100000 {
			compatible = "syscon";
			reg = <0x1100000 0xafff>;
			phandle = <0x0f>;
		};

		sdcc1ice@7803000 {
			compatible = "qcom,ice";
			reg = <0x7803000 0x2000>;
			interrupts = <0x00 0x138 0x04>;
			qcom,msm-bus,vectors-KBps = <0x4e 0x200 0x00 0x00 0x4e 0x200 0x3e8 0x00>;
			qcom,bus-vector-names = "MIN\0MAX";
			qcom,instance-type = "sdcc";
			phandle = <0x0d>;
		};

		sdhci@7824900 {
			compatible = "qcom,sdhci-msm-v4";
			reg = <0x7824900 0x500 0x7824000 0x800>;
			reg-names = "hc_mem\0core_mem";
			interrupts = <0x00 0x7b 0x04 0x00 0x8a 0x04>;
			interrupt-names = "hc_irq\0pwr_irq";
			sdhc-msm-crypto = <0x0d>;
			clocks = <0x0e 0x09 0x89 0x09 0x8a 0x09 0x8b>;
			clock-names = "xo\0iface\0core\0ice_core_clk";
			qcom,ice-clk-rates = <0x9896800 0x12646790>;
			max-frequency = <0x16e36000>;
			syscon = <0x0f 0xa000 0x19e5b>;
			mmc-ddr-1_8v;
			mmc-hs200-1_8v;
			mmc-hs400-1_8v;
			mmc-hs400-enhanced-strobe;
			bus-width = <0x08>;
			non-removable;
			status = "disabled";
		};

		sd-pwrseq {
			compatible = "mmc-pwrseq-ipq";
			reset-gpios = <0x10 0x15 0x00>;
			status = "disabled";
			phandle = <0x12>;
		};

		sdhci@7864900 {
			compatible = "qcom,sdhci-msm-v4";
			reg = <0x7864900 0x500 0x7864000 0x800>;
			reg-names = "hc_mem\0core_mem";
			interrupts = <0x00 0x7d 0x04 0x00 0xdd 0x04>;
			interrupt-names = "hc_irq\0pwr_irq";
			clocks = <0x0e 0x09 0x8c 0x09 0x8d>;
			clock-names = "xo\0iface\0core";
			max-frequency = <0xb71b000>;
			mmc-ddr-1_8v;
			mmc-hs200-1_8v;
			bus-width = <0x04>;
			vqmmc-supply = <0x11>;
			mmc-pwrseq = <0x12>;
			status = "disabled";
		};

		qcom,test@0 {
			compatible = "qcom,testmhi";
			qcom,wlan-ramdump-dynamic = <0x400000>;
			status = "disabled";
		};

		dma@7884000 {
			compatible = "qcom,bam-v1.7.0";
			reg = <0x7884000 0x2b000>;
			interrupts = <0x00 0xee 0x04>;
			clocks = <0x09 0x15>;
			clock-names = "bam_clk";
			#dma-cells = <0x01>;
			qcom,ee = <0x00>;
			phandle = <0x13>;
		};

		serial@78af000 {
			compatible = "qcom,msm-uartdm-v1.4\0qcom,msm-uartdm";
			reg = <0x78af000 0x200>;
			interrupts = <0x00 0x6b 0x04>;
			clocks = <0x09 0x22 0x09 0x15>;
			clock-names = "core\0iface";
			status = "disabled";
		};

		serial@78b0000 {
			compatible = "qcom,msm-uartdm-v1.4\0qcom,msm-uartdm";
			reg = <0x78b0000 0x200>;
			interrupts = <0x00 0x6c 0x04>;
			clocks = <0x09 0x23 0x09 0x15>;
			clock-names = "core\0iface";
			status = "disabled";
		};

		serial@78b1000 {
			compatible = "qcom,msm-uartdm-v1.4\0qcom,msm-uartdm";
			reg = <0x78b1000 0x200>;
			interrupts = <0x00 0x132 0x04>;
			clocks = <0x09 0x24 0x09 0x15>;
			clock-names = "core\0iface";
			dmas = <0x13 0x04 0x13 0x05>;
			dma-names = "tx\0rx";
			pinctrl-0 = <0x14>;
			pinctrl-names = "default";
			status = "disabled";
		};

		spi@78b5000 {
			compatible = "qcom,spi-qup-v2.2.1";
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			reg = <0x78b5000 0x600>;
			interrupts = <0x00 0x5f 0x04>;
			spi-max-frequency = <0x2faf080>;
			clocks = <0x09 0x17 0x09 0x15>;
			clock-names = "core\0iface";
			dmas = <0x13 0x0c 0x13 0x0d>;
			dma-names = "tx\0rx";
			pinctrl-0 = <0x15>;
			pinctrl-names = "default";
			status = "ok";
			cs-select = <0x00>;

			m25p80@0 {
				compatible = "n25q128a11";
				#address-cells = <0x01>;
				#size-cells = <0x01>;
				reg = <0x00>;
				spi-max-frequency = <0x2faf080>;
			};
		};

		spi@78b8000 {
			compatible = "qcom,spi-qup-v2.2.1";
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			reg = <0x78b8000 0x600>;
			interrupts = <0x00 0x62 0x04>;
			spi-max-frequency = <0x2faf080>;
			clocks = <0x09 0x1d 0x09 0x15>;
			clock-names = "core\0iface";
			dmas = <0x13 0x12 0x13 0x13>;
			dma-names = "tx\0rx";
			status = "disabled";
		};

		spi@78ba000 {
			compatible = "qcom,spi-qup-v2.2.1";
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			reg = <0x78ba000 0x600>;
			interrupts = <0x00 0x64 0x04>;
			spi-max-frequency = <0x2faf080>;
			clocks = <0x09 0x21 0x09 0x15>;
			clock-names = "core\0iface";
			dmas = <0x13 0x0a 0x13 0x0b>;
			dma-names = "tx\0rx";
			status = "disabled";
		};

		i2c@78b6000 {
			compatible = "qcom,i2c-qup-v2.2.1";
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			reg = <0x78b6000 0x600>;
			interrupts = <0x00 0x60 0x04>;
			clocks = <0x09 0x15 0x09 0x18>;
			clock-names = "iface\0core";
			clock-frequency = <0x61a80>;
			dmas = <0x13 0x0f 0x13 0x0e>;
			dma-names = "rx\0tx";
			pinctrl-0 = <0x16>;
			pinctrl-names = "default";
			status = "disabled";
		};

		i2c@78b7000 {
			compatible = "qcom,i2c-qup-v2.2.1";
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			reg = <0x78b7000 0x600>;
			interrupts = <0x00 0x61 0x04>;
			clocks = <0x09 0x15 0x09 0x1a>;
			clock-names = "iface\0core";
			clock-frequency = <0x186a0>;
			dmas = <0x13 0x11 0x13 0x10>;
			dma-names = "rx\0tx";
			status = "disabled";
		};

		i2c@78b9000 {
			compatible = "qcom,i2c-qup-v2.2.1";
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			reg = <0x78b9000 0x600>;
			interrupts = <0x00 0x12b 0x04>;
			clocks = <0x09 0x15 0x09 0x1e>;
			clock-names = "iface\0core";
			clock-frequency = <0x61a80>;
			dmas = <0x13 0x15 0x13 0x14>;
			dma-names = "rx\0tx";
			status = "disabled";
		};

		i2c@78ba000 {
			compatible = "qcom,i2c-qup-v2.2.1";
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			reg = <0x78ba000 0x600>;
			interrupts = <0x00 0x12c 0x04>;
			clocks = <0x09 0x15 0x09 0x20>;
			clock-names = "iface\0core";
			clock-frequency = <0x186a0>;
			dmas = <0x13 0x17 0x13 0x16>;
			dma-names = "rx\0tx";
			status = "disabled";
		};

		qti,rpm-log@29fc00 {
			compatible = "qti,rpm-log";
			reg = <0x29fc00 0x4000>;
			qti,rpm-addr-phys = <0x200000>;
			qti,offset-version = <0x04>;
			qti,offset-page-buffer-addr = <0x24>;
			qti,offset-log-len = <0x28>;
			qti,offset-log-len-mask = <0x2c>;
			qti,offset-page-indices = <0x38>;
		};

		qcom,spmi@200f000 {
			compatible = "qcom,spmi-pmic-arb";
			reg = <0x200f000 0x1000 0x2400000 0x800000 0x2c00000 0x800000 0x3800000 0x200000 0x200a000 0x700>;
			reg-names = "core\0chnls\0obsrvr\0intr\0cnfg";
			interrupts = <0x00 0xbe 0x04>;
			interrupt-names = "periph_irq";
			qcom,ee = <0x00>;
			qcom,channel = <0x00>;
			#address-cells = <0x02>;
			#size-cells = <0x00>;
			interrupt-controller;
			#interrupt-cells = <0x04>;
			cell-index = <0x00>;

			pmic@0 {
				compatible = "qcom,spmi-pmic";
				reg = <0x00 0x00>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;

